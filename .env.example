# zEnv Production Configuration
# Copy to .env and fill in values before running docker-compose.prod.yml

# --- Postgres ---
POSTGRES_USER=zenv
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=zenv

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME

# --- API Server ---
API_PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=info

# --- Auth Server ---
AUTH_PORT=3000
BETTER_AUTH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3001
COOKIE_DOMAIN=

# --- OAuth (optional — omit to disable) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

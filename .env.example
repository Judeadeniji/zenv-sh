# zEnv Production Configuration
# Copy to .env and fill in all CHANGE_ME values before running.
#
# Local (pg + redis bundled):
#   docker compose -f docker-compose.prod.yml --profile local up --build
#
# Prod (3rd-party pg + redis):
#   docker compose -f docker-compose.prod.yml up --build -d

# --- Postgres (local profile only — omit in prod, use DATABASE_URL instead) ---
POSTGRES_USER=zenv
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=zenv

# --- Redis (local profile only — omit in prod, use REDIS_URL instead) ---
REDIS_PASSWORD=CHANGE_ME

# --- External DB / Redis (prod — leave blank to use local profile containers) ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
# REDIS_URL=rediss://:pass@host:6379/0

# --- API Server ---
CORS_ORIGINS=https://app.yourdomain.com
LOG_LEVEL=info

# --- Auth Server ---
BETTER_AUTH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
BETTER_AUTH_URL=https://auth.yourdomain.com
APP_URL=https://app.yourdomain.com
TRUSTED_ORIGINS=https://app.yourdomain.com
COOKIE_DOMAIN=yourdomain.com

# --- OAuth (optional — omit to disable) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Caddy ---
# Prod:  set real domains + ACME_EMAIL → auto TLS via Let's Encrypt
# Local: set *.localhost domains, leave ACME_EMAIL blank → Caddy local CA
#        (run `docker exec <caddy-container> caddy trust` once to trust the CA)
ACME_EMAIL=admin@yourdomain.com
APP_DOMAIN=app.yourdomain.com
AUTH_DOMAIN=auth.yourdomain.com
API_DOMAIN=api.yourdomain.com

# --- Local overrides (when using --profile local) ---
# BETTER_AUTH_URL=https://auth.zenv.localhost
# APP_URL=https://app.zenv.localhost
# TRUSTED_ORIGINS=https://app.zenv.localhost
# CORS_ORIGINS=https://app.zenv.localhost
# COOKIE_DOMAIN=zenv.localhost
# APP_DOMAIN=app.zenv.localhost
# AUTH_DOMAIN=auth.zenv.localhost
# API_DOMAIN=api.zenv.localhost
# ACME_EMAIL=

{
  "name": "@zenv/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --minify=true --outfile=dist/index.js --packages=external --sourcemap",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=.env dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@t3-oss/env-core": "^0.13.10",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0",
    "postgres": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.12",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}

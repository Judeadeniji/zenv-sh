---
/**
 * Reusable link card with icon. Supports 3 variants:
 * - "card" (default): bordered card with shadow (card-clerk class)
 * - "flat": borderless, icon + text side by side
 * - "preview": card with colored gradient preview area on top
 */
interface Props {
	href: string;
	title: string;
	description: string;
	icon: string;
	variant?: 'card' | 'flat' | 'preview';
	previewColor?: string;
}

const { href, title, description, icon, variant = 'card', previewColor = 'accent' } = Astro.props;

const colorMap: Record<string, { gradient: string; text: string }> = {
	accent: { gradient: 'from-accent-600/20 via-accent-500/10 dark:from-accent-400/15 dark:via-accent-500/5', text: 'text-accent-600/40 dark:text-accent-400/30' },
	blue: { gradient: 'from-blue-600/20 via-blue-500/10 dark:from-blue-400/15 dark:via-blue-500/5', text: 'text-blue-600/40 dark:text-blue-400/30' },
	emerald: { gradient: 'from-emerald-600/20 via-emerald-500/10 dark:from-emerald-400/15 dark:via-emerald-500/5', text: 'text-emerald-600/40 dark:text-emerald-400/30' },
	amber: { gradient: 'from-amber-600/20 via-amber-500/10 dark:from-amber-400/15 dark:via-amber-500/5', text: 'text-amber-600/40 dark:text-amber-400/30' },
};

const colors = colorMap[previewColor] || colorMap.accent;
---

{variant === 'flat' ? (
	<a href={href} class="group flex items-start gap-4 no-underline">
		<div class="w-10 h-10 shrink-0 flex items-center justify-center text-gray-400 dark:text-gray-500 group-hover:text-gray-950 dark:group-hover:text-white transition-colors duration-200">
			<Fragment set:html={icon} />
		</div>
		<div>
			<h3 class="text-[0.9375rem] font-semibold text-gray-950 dark:text-white mb-1">{title}</h3>
			<p class="text-[0.8125rem] text-gray-500 dark:text-gray-400 leading-[1.5] m-0">{description}</p>
		</div>
	</a>
) : variant === 'preview' ? (
	<a href={href} class="group no-underline rounded-xl overflow-hidden ring-1 ring-gray-900/7 dark:ring-white/7 transition-shadow duration-200 hover:shadow-[0_1px_4px_0_rgba(0,0,0,0.12),0_4px_8px_0_rgba(0,0,0,0.08)]">
		<div class:list={['h-36 bg-linear-to-br to-transparent flex items-center justify-center', colors.gradient]}>
			<div class:list={[colors.text]}>
				<Fragment set:html={icon} />
			</div>
		</div>
		<div class="p-4">
			<h3 class="text-[0.9375rem] font-semibold text-gray-950 dark:text-white mb-1">{title}</h3>
			<p class="text-[0.8125rem] text-gray-500 dark:text-gray-400 leading-[1.5] m-0">{description}</p>
		</div>
	</a>
) : (
	<a href={href} class="card-clerk group flex items-start gap-4">
		<div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg bg-gray-900/3 dark:bg-white/7 text-gray-500 dark:text-gray-400 group-hover:text-gray-950 dark:group-hover:text-white transition-colors duration-100">
			<Fragment set:html={icon} />
		</div>
		<div>
			<h3 class="text-[0.9375rem] font-semibold text-gray-950 dark:text-white mb-1">{title}</h3>
			<p class="text-[0.8125rem] text-gray-500 dark:text-gray-400 leading-[1.5] m-0">{description}</p>
		</div>
	</a>
)}

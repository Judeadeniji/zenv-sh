---
import { getPrevNext } from '../data/sidebar';
import Feedback from './Feedback.astro';

interface Props {
	currentSlug: string;
}

const { currentSlug } = Astro.props;
const { prev, next } = getPrevNext(currentSlug);
const editUrl = `https://github.com/Judeadeniji/zenv-sh/edit/main/apps/docs/src/content/docs/${currentSlug}.mdx`;
---

{/* Prev / Next navigation */}
<nav class="mt-16 border-t border-gray-900/7 dark:border-white/7 pt-6">
	<div class="flex items-center justify-between gap-4">
		{prev ? (
			<a href={`/${prev.slug}/`} class="group flex items-center gap-2 text-[0.8125rem] text-gray-500 dark:text-gray-400 hover:text-gray-950 dark:hover:text-white transition-colors duration-100 no-underline">
				<svg class="w-4 h-4 transition-transform duration-100 group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 19.5 8.25 12l7.5-7.5" />
				</svg>
				<span>{prev.label}</span>
			</a>
		) : <div />}

		{next ? (
			<a href={`/${next.slug}/`} class="group flex items-center gap-2 text-[0.8125rem] text-gray-500 dark:text-gray-400 hover:text-gray-950 dark:hover:text-white transition-colors duration-100 ml-auto no-underline">
				<span>{next.label}</span>
				<svg class="w-4 h-4 transition-transform duration-100 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
				</svg>
			</a>
		) : <div />}
	</div>
</nav>

{/* Feedback section */}
<Feedback />

{/* Last updated + Edit on GitHub */}
<div class="mt-8 flex items-center justify-between text-[0.75rem] text-gray-400 dark:text-gray-500">
	<span>Last updated on {new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
	<a href={editUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-gray-400 dark:text-gray-500 hover:text-gray-950 dark:hover:text-white no-underline transition-colors duration-100">
		<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
			<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
		</svg>
		Edit on GitHub
		<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
		</svg>
	</a>
</div>

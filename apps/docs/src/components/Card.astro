---
interface Props {
	title: string;
	icon?: string;
}

const { title, icon } = Astro.props;

const iconMap: Record<string, string> = {
	'approve-check': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />',
	'laptop': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" />',
	'setting': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 1 1 0 6H5.25a3 3 0 0 1-3-3Zm16.5 0h.008v.008h-.008V11.25Z" />',
	'random': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />',
};

const svgContent = icon && iconMap[icon] ? iconMap[icon] : null;
---

<div class="card-clerk">
	{svgContent && (
		<div class="w-8 h-8 mb-3 flex items-center justify-center rounded-md bg-[rgba(0,0,0,0.03)] dark:bg-[rgba(255,255,255,0.07)] text-gray-500 dark:text-gray-400">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={svgContent} />
		</div>
	)}
	<h3 class="text-[0.8125rem] font-bold text-gray-950 dark:text-white mb-1 leading-[1.38]">{title}</h3>
	<div class="text-[0.8125rem] text-gray-500 dark:text-gray-400 leading-[1.38] font-normal">
		<slot />
	</div>
</div>

---
import ThemeToggle from './ThemeToggle.astro';
import Button from './Button.astro';
---

<header class="sticky top-0 z-40 h-14 bg-white/80 dark:bg-gray-950/80 backdrop-blur-md border-b border-gray-900/7 dark:border-white/7">
	<div class="flex items-center justify-between h-full px-4 lg:px-6">
		<!-- Left: Mobile menu button only (logo is in sidebar) -->
		<div class="flex items-center">
			<button
				id="mobile-menu-btn"
				class="lg:hidden p-1.5 -ml-1.5 rounded-md text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 hover:bg-gray-900/3 dark:hover:bg-white/7 transition-all duration-100"
				aria-label="Toggle menu"
			>
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
				</svg>
			</button>
		</div>

		<!-- Center: Search + Ask AI -->
		<div class="hidden md:flex items-center gap-2">
			<button
				class="flex items-center gap-2 h-8 px-3 w-56 rounded-md text-gray-400 dark:text-gray-500 text-[0.8125rem] transition-all duration-100 ring-1 ring-gray-900/10 dark:ring-white/10 hover:ring-gray-900/15 dark:hover:ring-white/15 bg-white dark:bg-white/5"
				aria-label="Search documentation"
			>
				<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
				</svg>
				<span class="truncate">Search documentation</span>
				<kbd class="ml-auto shrink-0 text-[0.625rem] font-mono text-gray-400 dark:text-gray-500 bg-gray-900/3 dark:bg-white/7 ring-1 ring-gray-900/7 dark:ring-white/7 rounded px-1 py-px">Ctrl K</kbd>
			</button>

			<Button href="#" variant="outline" class="h-8 px-3 text-[0.8125rem]">
				Ask AI
			</Button>
		</div>

		<!-- Right: Sign Up -->
		<div class="flex items-center gap-2">
			<ThemeToggle />
			<Button href="https://github.com/Judeadeniji/zenv-sh" external class="hidden sm:inline-flex">
				Sign Up
				<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
				</svg>
			</Button>
		</div>
	</div>
</header>

<!-- Mobile overlay -->
<div id="mobile-overlay" class="fixed inset-0 z-50 hidden lg:hidden" style="background: rgba(0,0,0,0.27);">
	<div id="mobile-drawer" class="absolute inset-y-0 left-0 w-72 bg-white dark:bg-gray-950 border-r border-gray-900/7 dark:border-white/7 overflow-y-auto p-4 transform -translate-x-full transition-transform duration-200 ease-[cubic-bezier(0.32,0.72,0,1)]">
		<div class="flex items-center justify-between mb-4">
			<a href="/" class="flex items-center gap-2 text-gray-950 dark:text-white no-underline">
				<svg class="w-5.5 h-5.5" viewBox="0 0 24 24" fill="none">
					<rect width="24" height="24" rx="6" fill="currentColor" />
					<path d="M7 8h10M7 12h6M7 16h8" stroke="white" stroke-width="1.5" stroke-linecap="round" class="dark:stroke-gray-950" />
				</svg>
				<span class="font-semibold text-[0.8125rem]">zEnv</span>
			</a>
			<button id="mobile-close-btn" class="p-1 rounded-md text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors duration-100" aria-label="Close menu">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		</div>
		<div id="mobile-sidebar-content"></div>
	</div>
</div>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const overlay = document.getElementById('mobile-overlay');
	const drawer = document.getElementById('mobile-drawer');
	const closeBtn = document.getElementById('mobile-close-btn');

	function openMenu() {
		overlay?.classList.remove('hidden');
		requestAnimationFrame(() => drawer?.classList.remove('-translate-x-full'));
	}
	function closeMenu() {
		drawer?.classList.add('-translate-x-full');
		setTimeout(() => overlay?.classList.add('hidden'), 200);
	}

	btn?.addEventListener('click', openMenu);
	closeBtn?.addEventListener('click', closeMenu);
	overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeMenu(); });
</script>

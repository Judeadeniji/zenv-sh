---

<div class="tabs-container not-prose my-4" data-tabs>
	<slot />
</div>

<script>
	document.querySelectorAll<HTMLDivElement>('[data-tabs]').forEach((container) => {
		const panels = container.querySelectorAll<HTMLDivElement>('[data-tab-panel]');
		if (panels.length === 0) return;

		const bar = document.createElement('div');
		bar.className = 'flex border-b mb-3 gap-0';
		bar.style.borderColor = 'rgba(0,0,0,0.07)';

		// Dark mode border
		if (document.documentElement.classList.contains('dark')) {
			bar.style.borderColor = 'rgba(255,255,255,0.07)';
		}

		panels.forEach((panel, i) => {
			const label = panel.dataset.tabPanel || `Tab ${i + 1}`;
			const btn = document.createElement('button');
			btn.textContent = label;
			btn.style.cssText = 'padding: 0.375rem 0.75rem; font-size: 0.8125rem; font-weight: 500; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 100ms ease; cursor: pointer; background: none; border-top: 0; border-left: 0; border-right: 0;';

			if (i === 0) {
				btn.style.borderBottomColor = '#131316';
				btn.style.color = '#131316';
				if (document.documentElement.classList.contains('dark')) {
					btn.style.borderBottomColor = 'white';
					btn.style.color = 'white';
				}
				panel.style.display = '';
			} else {
				btn.style.color = '#868e96';
				panel.style.display = 'none';
			}

			btn.addEventListener('click', () => {
				const isDark = document.documentElement.classList.contains('dark');
				bar.querySelectorAll('button').forEach((b) => {
					b.style.borderBottomColor = 'transparent';
					b.style.color = '#868e96';
				});
				panels.forEach((p) => (p.style.display = 'none'));

				btn.style.borderBottomColor = isDark ? 'white' : '#131316';
				btn.style.color = isDark ? 'white' : '#131316';
				panel.style.display = '';
			});

			bar.appendChild(btn);
		});

		container.prepend(bar);
	});
</script>
